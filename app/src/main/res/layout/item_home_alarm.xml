<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/card_memory"
    android:layout_height="wrap_content"
    android:layout_width="match_parent"
    android:layout_marginHorizontal="50dp"
    android:layout_marginTop="12dp"
    app:cardCornerRadius="15dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#E5E6FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center_horizontal">

        <!-- ✅ GPS 버튼 + 제목 (상단) -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- ✅ GPS 버튼 추가 (왼쪽) -->
            <ImageButton
                android:id="@+id/btn_gps"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentStart="true"
                android:src="@drawable/ic_location_point"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="GPS 베어링 버튼"
                android:padding="8dp"
                app:tint="@color/gray"
                android:visibility="gone"/>

            <!-- ✅ 제목 (중앙) -->
            <TextView
                android:id="@+id/text_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="제목"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/black"
                android:gravity="center"
                tools:text="제목" />
        </RelativeLayout>

        <!-- ✅ 날짜 (기존 유지) -->
        <TextView
            android:id="@+id/text_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="2025.10.15"
            android:textSize="14sp"
            android:textColor="@color/black"
            tools:text="2025.10.15" />

        <!-- ✅ 위치 (기존 유지) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageView
                android:id="@+id/image_location_point"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="4dp"
                android:src="@drawable/ic_location_point"
                app:tint="@color/gray" />

            <TextView
                android:id="@+id/text_location"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Room 6-205"
                android:textColor="@color/gray"
                android:textSize="13sp"
                tools:text="Room 6-205" />
        </LinearLayout>

        <!-- ✅ 시간 (기존 유지) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/text_start_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12:00"
                android:textColor="@color/black"
                android:textSize="15sp"
                tools:text="12:00" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:text="–"
                android:textColor="@color/black"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/text_end_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="13:05"
                android:textColor="@color/black"
                android:textSize="15sp"
                tools:text="13:05" />
        </LinearLayout>

        <!-- ✅ GPS 베어링 정보 (GPS 활성화 시만 표시) 추가 -->
        <LinearLayout
            android:id="@+id/layout_bearing_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <!-- 화살표 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <!-- 현재 방향 화살표 (센서 기반) -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginEnd="24dp">

                    <ImageView
                        android:id="@+id/iv_current_direction"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_navigation_arrow"
                        android:contentDescription="현재 방향"
                        app:tint="#4CAF50"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="현재"
                        android:textSize="12sp"
                        android:textColor="@color/gray"/>
                </LinearLayout>

                <!-- 목적지 방향 화살표 (베어링 계산) -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/iv_dest_direction"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_arrow"
                        android:contentDescription="목적지 방향"
                        app:tint="#FF5722"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="목적지"
                        android:textSize="12sp"
                        android:textColor="@color/gray"/>
                </LinearLayout>
            </LinearLayout>

            <!-- 거리 텍스트 -->
            <TextView
                android:id="@+id/tv_distance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="📍 남은 거리: 0.0 km"
                android:textSize="14sp"
                android:textColor="@color/black"
                android:textStyle="bold"/>
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>